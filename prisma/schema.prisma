generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  photoUrl      String?
  role          String    @default("member")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  membership      Membership?
  bookings        Booking[]
  savedAddresses  SavedAddress[]
  ridePreference  RidePreference?
  ratings         Rating[]
  eventRsvps      EventRsvp[]
}

model Membership {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  program         String
  status          String   @default("active")
  startDate       DateTime
  endDate         DateTime?
  guestPassesUsed Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  guests          MembershipGuest[]
}

model MembershipGuest {
  id           String     @id @default(cuid())
  membershipId String
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  name         String
  phone        String?
  email        String?
  createdAt    DateTime   @default(now())
}

model Booking {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime
  pickupTime      String
  returnTime      String?
  pickupAddress   String
  dropoffAddress  String?
  vehicleRequest  String?
  vehicleAssigned String?
  vehicleId       String?
  vehicle         Vehicle? @relation(fields: [vehicleId], references: [id])
  status          String   @default("pending")
  passengers      Int      @default(1)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  inspections     VehicleInspection[]
  rating          Rating?
}

model Vehicle {
  id          String   @id @default(cuid())
  name        String
  type        String
  plate       String?
  color       String?
  status      String   @default("available")
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings    Booking[]
  inspections VehicleInspection[]
}

model VehicleInspection {
  id         String   @id @default(cuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type       String
  notes      String?
  createdAt  DateTime @default(now())

  photos     InspectionPhoto[]
}

model InspectionPhoto {
  id           String            @id @default(cuid())
  inspectionId String
  inspection   VehicleInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  photoData    String
  caption      String?
  createdAt    DateTime          @default(now())
}

model SavedAddress {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  label   String
  address String
  createdAt DateTime @default(now())

  @@unique([userId, address])
}

model RidePreference {
  id              String @id @default(cuid())
  userId          String @unique
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleRequest  String?
  passengers      Int    @default(1)
  notes           String?
  updatedAt       DateTime @updatedAt
}

model Rating {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stars     Int
  comment   String?
  createdAt DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  location    String?
  capacity    Int?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rsvps       EventRsvp[]
}

model EventRsvp {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  status  String @default("attending")
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  program   String
  message   String?
  status    String   @default("new")
  source    String?
  convertedUserId String?
  convertedAt     DateTime?
  createdAt DateTime @default(now())
}
